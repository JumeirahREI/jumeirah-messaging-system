# Database connection (libSQL).
# Dev: local SQLite file — no auth token needed.
# Prod (Turso): libsql://your-db.turso.io + TURSO_AUTH_TOKEN below.
TURSO_DATABASE_URL=file:./dev.db
# TURSO_AUTH_TOKEN=your-turso-auth-token

# NextAuth.js (Auth.js v5) signing secret (any long random string, >= 32 chars)
AUTH_SECRET=change-me-to-a-long-random-string
# AUTH_URL=https://your-site.netlify.app  # production base URL

# SMS Gateway — Alawaeltec (AlawaelSmsGateway).
# When ALAWAEL_ORG_NAME + ALAWAEL_USERNAME + ALAWAEL_PASSWORD are all set,
# getSmsGateway() returns AlawaelSmsGateway (real provider). Otherwise it
# falls back to FakeSmsGateway (dev/logs to console).
# ALAWAEL_ORG_NAME=
# ALAWAEL_USERNAME=
# ALAWAEL_PASSWORD=
# ALAWAEL_SEND_URL=https://sms.alawaeltec.com/MainServlet
# ALAWAEL_BALANCE_URL=http://185.216.203.97:8070/AlawaelEstalam
# ALAWAEL_CODING=2

# FakeSmsGateway simulated failure rate (0-1). Dev only.
# SMS_FAIL_RATE=0
