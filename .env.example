# Database connection (libSQL).
# Dev: local SQLite file — no auth token needed.
# Prod (Turso): libsql://your-db.turso.io + TURSO_AUTH_TOKEN below.
TURSO_DATABASE_URL=file:./dev.db
# TURSO_AUTH_TOKEN=your-turso-auth-token

# NextAuth.js (Auth.js v5) signing secret (any long random string, >= 32 chars)
AUTH_SECRET=change-me-to-a-long-random-string
# AUTH_URL=https://your-site.netlify.app  # production base URL

# SMS Gateway — Alawaeltec (AlawaelSmsGateway).
# When ALAWAEL_ORG_NAME + ALAWAEL_USERNAME + ALAWAEL_PASSWORD are all set,
# getSmsGateway() returns AlawaelSmsGateway (real provider). Otherwise it
# falls back to FakeSmsGateway (dev/logs to console).
# ALAWAEL_ORG_NAME=
# ALAWAEL_USERNAME=
# ALAWAEL_PASSWORD=
# ALAWAEL_SEND_URL=https://sms.alawaeltec.com/MainServlet
# ALAWAEL_BALANCE_URL=https://your-https-balance-endpoint
# ALAWAEL_CODING=2

# FakeSmsGateway simulated failure rate (0-1). Dev only.
# SMS_FAIL_RATE=0

# Netlify background function auth — shared secret between Next.js server
# and the process-batch-background function. Generate a long random string.
# NETLIFY_FUNCTION_SECRET=

# Upstash Redis (rate limiting). Required in production for rate limiting.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Database seed script — admin credentials.
# SEED_ADMIN_USERNAME=admin
# SEED_ADMIN_PASSWORD=  (required when running db:seed)

# Sentry — DSN shared by all runtimes (client/server/edge).
# Public DSN (browser): NEXT_PUBLIC_SENTRY_DSN. Server/edge: SENTRY_DSN.
# NEXT_PUBLIC_SENTRY_DSN=https://<key>@o<org>.ingest.de.sentry.io/<project>
# SENTRY_DSN=https://<key>@o<org>.ingest.de.sentry.io/<project>
# Source map upload (build-time only). Create at sentry.io Account Settings > Auth Tokens.
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
