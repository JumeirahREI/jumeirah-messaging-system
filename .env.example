# Database connection (libSQL).
# Dev: local SQLite file — no auth token needed.
# Prod (Turso): libsql://your-db.turso.io + TURSO_AUTH_TOKEN below.
TURSO_DATABASE_URL=file:./dev.db
# TURSO_AUTH_TOKEN=your-turso-auth-token

# NextAuth.js (Auth.js v5) signing secret (any long random string, >= 32 chars)
AUTH_SECRET=change-me-to-a-long-random-string
# AUTH_URL=https://your-site.netlify.app  # production base URL
